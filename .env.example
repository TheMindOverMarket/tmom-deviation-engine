# ── tmom-deviation-engine ────────────────────────────────
# Copy this to .env and fill in the values

# Backend API (Vallab's tmom-app-backend on Render)
TMOM_BACKEND_BASE_URL=https://tmom-app-backend.onrender.com
TMOM_BACKEND_WS_BASE_URL=

# Rule Engine (Abhinav's Rule-Engine — only needed if connecting directly)
TMOM_RULE_ENGINE_BASE_URL=https://rule-engine-rcg9.onrender.com

# This service
DEVIATION_ENGINE_HOST=0.0.0.0
DEVIATION_ENGINE_PORT=8100
ENVIRONMENT=development

# Engine tuning
DEFAULT_EXPIRY_WINDOW=60.0
LATE_ENTRY_GRACE_MS=30000
